# ── FolioFYX backend environment ──────────────────────────────────────────────
# Copy to ./server/.env and fill in real values. NEVER commit the real .env.

# Server
PORT=5000
NODE_ENV=production

# Database (MongoDB connection string — e.g. MongoDB Atlas)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/foliofyx

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# AI (Groq) — server-side ONLY. Keys are never sent to the browser.
# Preferred: several keys, comma-separated — the pool rotates across them and
# fails over on rate limits so simultaneous users never stall.
GROQ_API_KEYS=gsk_key_one,gsk_key_two,gsk_key_three
# Legacy single key (still works; merged into the pool):
GROQ_API_KEY=gsk_your_groq_api_key_here

# Python interpreter for the RAG engine + CV scripts (defaults to "python" on PATH)
# PYTHON_BIN=python

# Published-site serving (SSR of /site/:slug and custom domains)
# Public base URL of THIS server (used in publishedUrl). Defaults to the request host.
# PUBLIC_SITE_BASE=https://api.foliofyx.in
# Static IP users point their apex A record at (enables the "live" DNS check):
# SITE_SERVER_IP=203.0.113.10
# CNAME target users point www at:
# SITE_CNAME_TARGET=sites.foliofyx.in

# Any other integrations your deploy uses (payments, Google auth, Anthropic, etc.)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# GOOGLE_CLIENT_ID=
# ANTHROPIC_API_KEY=
